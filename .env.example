# Environment Variables for Quiz Arena Backend

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/quiz-arena

# JWT Secrets
JWT_SECRET=your_jwt_secret_here
JWT_SECRET_DASHBOARD=your_dashboard_jwt_secret_here

# Admin Secrets (optional, defaults provided)
ADMIN_SECRET=admin123
MODERATOR_SECRET=mod123
MANAGER_SECRET=manager123

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Quiz Arena" <noreply@quizarena.in>